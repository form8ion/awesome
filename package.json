{
  "name": "awesome",
  "description": "A curated list of form8ion related tools",
  "license": "CC0",
  "private": true,
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "form8ion/awesome",
  "bugs": "https://github.com/form8ion/awesome/issues",
  "homepage": "https://github.com/form8ion/awesome#readme",
  "scripts": {
    "test": "npm-run-all --print-label --parallel lint:*",
    "lint:md": "remark . --frail",
    "lint:sensitive": "ban",
    "lint:peer": "npm ls >/dev/null",
    "generate:md": "remark . --output",
    "prepare": "husky install",
    "lint:lockfile": "lockfile-lint"
  },
  "packageManager": "npm@11.11.1+sha512.6ac6b30a876415dcf545e433ba4cb34bf0c3efbb86088a9415e446de0b5a4fc6fd511d277b59bd40e06e3204fbda28f5aeded346b3a8c780355b39ed31622e12",
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@form8ion/commitlint-config": "2.0.10",
    "@form8ion/remark-lint-preset": "6.0.7",
    "ban-sensitive-files": "1.10.11",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lockfile-lint": "5.0.0",
    "npm-run-all2": "8.0.4",
    "remark-cli": "12.0.1",
    "remark-toc": "9.0.0"
  }
}
